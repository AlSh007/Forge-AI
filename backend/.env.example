# Backend Environment Variables

PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/forgeai_dev

# GitHub Integration
GITHUB_TOKEN=your_github_token_here
GITHUB_APP_ID=your_app_id_here
GITHUB_APP_SECRET=your_app_secret_here

# LLM Provider (Groq — get key from console.groq.com/keys)
GROQ_API_KEY=

# CORS — set to your Vercel frontend URL in production (e.g. https://your-app.vercel.app)
# Leave unset in development to allow all origins.
CORS_ORIGIN=

# Sandbox
DOCKER_HOST=unix:///var/run/docker.sock

# Logging
LOG_LEVEL=debug
